#version 450

layout(local_size_x = 1) in;

layout(std430, set = 0, binding = 0) buffer In  { float _in[];  };
layout(std430, set = 0, binding = 1) buffer Out { float _out[]; };

void main() {
    uint i = gl_GlobalInvocationID.x;
    if (i == 0 || i >= 999) { _out[i] = _in[i]; return; }
    _out[i] = (_in[i-1] + _in[i] + _in[i+1]) / 3.0;
}
